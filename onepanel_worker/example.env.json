{
  "apiToken": "",
  "onepanel": {
    "baseUrl": "https://your-onepanel.example.com",
    "apiKey": "replace-with-your-onepanel-api-key",
    "apiPrefix": "/api/v1",
    "defaultContainerName": "yak"
  },
  "notification": {
    "gatewayBaseUrl": "https://your-feishu-bot-gateway.example.workers.dev",
    "gatewayAuthToken": "replace-with-your-feishu-bot-gateway-token",
    "appId": "cli_xxx",
    "templateId": "ctp_xxx",
    "templateVersionName": "1.0.0",
    "card": {
      "subButtonText": "打开 1Panel",
      "mainButtonDisabled": true
    }
  },
  "dockerRegistry": {
    "Ali-shenzhen": {
      "registry": "registry.cn-shenzhen.aliyuncs.com",
      "username": "your-username",
      "password": "your-password"
    }
  },
  "defaults": {
    "healthCheck": {
      "containers": [
        "yak",
        "subconverter"
      ]
    }
  }
}
